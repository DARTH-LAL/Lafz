SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/spotify/callback
OPENAI_API_KEY=your_openai_api_key
OPENAI_GENERATOR_A_MODEL=gpt-5.4-mini
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_GENERATOR_B_MODEL=claude-sonnet-4-20250514
GEMINI_API_KEY=your_gemini_api_key
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TRANSLATION_MODEL=gemini-2.5-flash
GEMINI_EVALUATOR_MODEL=gemini-2.5-pro
# Translation pipeline is fixed to OpenAI for Generator A, Gemini for Generator B, and Gemini for judge.
# Kept for compatibility with older setups; the desktop/main app no longer switches to the legacy three_model path.
LAFZ_TRANSLATION_PIPELINE_MODE=gemini_only
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Lafz Brain worker
# disabled = safe default for laptops
# embedded = worker runs inside the web app process
# standalone = use the daemon script against the protected internal worker route
LAFZ_AGENT_RUNTIME_MODE=disabled
LAFZ_AGENT_WORKER_POLL_MS=15000
LAFZ_AGENT_AUTO_BACKLOG_ENABLED=true
LAFZ_AGENT_BACKLOG_BATCH_SIZE=5
LAFZ_AGENT_BACKLOG_REFILL_COOLDOWN_MS=60000
LAFZ_AGENT_MAX_ATTEMPTS=3
LAFZ_AGENT_RETRY_BASE_MS=30000
LAFZ_AGENT_RETRY_MAX_MS=600000
LAFZ_AGENT_STALE_JOB_TIMEOUT_MS=900000
LAFZ_CLEANUP_AGENT_HEARTBEAT_MS=30000
LAFZ_AGENT_WORKER_ID=
LAFZ_AGENT_RUNNER_SECRET=
LAFZ_APP_URL=http://127.0.0.1:3000
LAFZ_API_BASE_URL=http://127.0.0.1:3000

# macOS desktop signing
# Default beta path: ad-hoc signing so the packaged app is signed without an Apple cert.
# Later, replace "-" with your Apple Developer ID signing identity if you have one.
APPLE_SIGNING_IDENTITY=-

# Desktop auto-update
# Set these to enable Tauri updater artifacts + in-app update checks.
# The update endpoint should serve the Tauri release manifest over HTTPS.
# For Cloudflare R2, use a public R2 base URL or your custom domain here.
LAFZ_UPDATE_BASE_URL=
LAFZ_UPDATE_PREFIX=desktop-updates
LAFZ_UPDATE_ENDPOINTS=
LAFZ_UPDATER_PUBKEY=
LAFZ_UPDATER_ALLOW_INSECURE=false
# Generated by `tauri signer generate` when you are ready to ship signed updater artifacts.
TAURI_SIGNING_PRIVATE_KEY=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# Desktop shell target. For local dev, keep this on localhost.
# For a packaged app, leave this unset unless you want to override the local desktop shell URL.
LAFZ_DESKTOP_URL=http://127.0.0.1:3001/index.html

# Desktop API base used by the packaged app. Prefer a deployed HTTPS app URL here.
LAFZ_DESKTOP_API_BASE_URL=

LAFZ_BRAIN_WORKER_AGENTS=vocabulary,entity,motif,persona,cleanup
LAFZ_BRAIN_WORKER_MAX_JOBS=3
