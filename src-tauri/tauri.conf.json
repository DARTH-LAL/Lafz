{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lafz",
  "version": "0.1.0",
  "identifier": "com.lafz.desktop",
  "build": {
    "devUrl": "http://127.0.0.1:3001/consumer",
    "frontendDist": "../desktop"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Lafz",
        "width": 1440,
        "height": 960,
        "minWidth": 1200,
        "minHeight": 780,
        "resizable": true,
        "visible": true,
        "create": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "macOS": {
      "entitlements": "./Entitlements.plist"
    },
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
