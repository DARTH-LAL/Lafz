{
  "name": "lafz",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:desktop": "next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "desktop": "LAFZ_DESKTOP_PORT=3001 node scripts/run-desktop-dev.mjs",
    "desktop:dev": "LAFZ_DESKTOP_PORT=3001 node scripts/run-desktop-dev.mjs",
    "desktop:app": "node scripts/run-desktop-build.mjs",
    "desktop:build": "node scripts/run-desktop-build.mjs",
    "desktop:dmg": "node scripts/build-desktop-dmg.mjs",
    "desktop:publish-update": "node scripts/publish-desktop-update.mjs",
    "typecheck": "tsc --noEmit",
    "backfill:supabase": "node --env-file=.env.local scripts/backfill-supabase.mjs",
    "backfill:r2": "node --env-file=.env.local scripts/backfill-r2.mjs",
    "backfill:brain": "node --env-file=.env.local scripts/backfill-brain.mjs",
    "backfill:brain:learning": "node --env-file=.env.local scripts/backfill-brain-learning.mjs",
    "backfill:brain:embeddings": "node --env-file=.env.local scripts/backfill-brain-embeddings.mjs",
    "backfill:published-art": "node --env-file=.env.local scripts/backfill-published-translation-art.mjs",
    "backfill:vocabulary:jobs": "node --env-file=.env.local scripts/enqueue-vocabulary-backlog.mjs",
    "reconcile:brain": "node --env-file=.env.local scripts/reconcile-brain.mjs",
    "reconcile:entity": "node --env-file=.env.local scripts/reconcile-entity-graph.mjs",
    "reconcile:motif": "node --env-file=.env.local scripts/reconcile-motif-graph.mjs",
    "audit:brain": "node --env-file=.env.local scripts/audit-brain.mjs",
    "benchmark:brain": "node --env-file=.env.local scripts/benchmark-brain.mjs",
    "benchmark:brain:critic": "node --no-warnings --experimental-strip-types scripts/benchmark-brain-critic.mjs",
    "benchmark:ai:surface-polish": "node --no-warnings --experimental-strip-types scripts/benchmark-ai-surface-polish.mjs",
    "ci:brain": "npm run typecheck && npm run benchmark:brain:critic",
    "ci:ai": "npm run typecheck && npm run benchmark:ai:surface-polish",
    "agent:vocabulary": "node --env-file=.env.local scripts/run-vocabulary-worker-daemon.mjs --once",
    "agent:vocabulary:daemon": "node --env-file=.env.local scripts/run-vocabulary-worker-daemon.mjs",
    "agent:entity": "node --env-file=.env.local scripts/run-entity-worker-daemon.mjs --once",
    "agent:entity:daemon": "node --env-file=.env.local scripts/run-entity-worker-daemon.mjs",
    "agent:motif": "node --env-file=.env.local scripts/run-motif-worker-daemon.mjs --once",
    "agent:motif:daemon": "node --env-file=.env.local scripts/run-motif-worker-daemon.mjs",
    "agent:persona": "node --env-file=.env.local scripts/run-persona-worker-daemon.mjs --once",
    "agent:persona:daemon": "node --env-file=.env.local scripts/run-persona-worker-daemon.mjs",
    "agent:cleanup": "node --env-file=.env.local scripts/run-cleanup-worker-daemon.mjs --once",
    "agent:cleanup:daemon": "node --env-file=.env.local scripts/run-cleanup-worker-daemon.mjs",
    "agent:brain": "node --env-file=.env.local scripts/run-brain-worker-daemon.mjs --once",
    "agent:brain:daemon": "node --env-file=.env.local scripts/run-brain-worker-daemon.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@supabase/supabase-js": "^2.100.1",
    "@swc/helpers": "^0.5.20",
    "@tauri-apps/api": "^2.10.1",
    "next": "^15.5.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-force-graph": "^1.48.2",
    "react-force-graph-2d": "^1.29.1",
    "react-force-graph-3d": "^1.29.1",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.12",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "postcss": "^8",
    "tailwindcss": "^4.1.12",
    "typescript": "^5"
  }
}
